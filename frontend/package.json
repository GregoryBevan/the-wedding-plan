{
  "name": "frontend",
  "version": "0.0.15",
  "type": "module",
  "scripts": {
    "dev:public": "vite public --config vite.config.ts",
    "dev:backoffice": "vite backoffice --config vite.config.ts",
    "build": "vite build",
    "preview": "vite preview",
    "version:issue": "pnpm version patch --no-git-tag-version",
    "version:issue:minor": "pnpm version minor --no-git-tag-version",
    "version:issue:major": "pnpm version major --no-git-tag-version",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "vue": "^3.5.38",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^24.13.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "4.1.9",
    "@vue/test-utils": "^2.4.11",
    "autoprefixer": "^10.5.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "8.0.16",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.5"
  }
}
