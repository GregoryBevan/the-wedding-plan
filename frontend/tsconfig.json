{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ESNext", "DOM"],
    "moduleResolution": "Bundler",
    "strict": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "noEmit": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "types": ["vite/client"]
  },
  "include": ["types/**/*.d.ts", "public/src/**/*.ts", "public/src/**/*.d.ts", "public/src/**/*.tsx", "public/src/**/*.vue", "backoffice/src/**/*.ts", "backoffice/src/**/*.d.ts", "backoffice/src/**/*.tsx", "backoffice/src/**/*.vue"]
}
